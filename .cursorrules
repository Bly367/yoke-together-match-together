{
  "version": 1,
  "project": "Yoke (Two-Man Dating App)",
  "goals": [
    "React + TypeScript + Supabase web app with duo matching and realtime group chat",
    "Zero duplication of functions or logic (DRY). Reuse shared utilities/components.",
    "High runtime efficiency and optimized performance (React best practices, code splitting, memoization).",
    "Clean, layered architecture that is easy to read and easy to edit."
  ],

  "global_instructions": [
    "NEVER duplicate functions or logic. If a function already exists, REUSE it, generalize it, or move it to a shared module (lib/, hooks/, services/, or components/) so all call sites use the same implementation.",
    "Prefer composition over inheritance. Follow SOLID principles. Keep components functional and hooks thin but stateful.",
    "Use async/await, proper error handling, and loading states. Avoid force unwrapping, avoid global singletons.",
    "All components must be functional and stateless where possible; state belongs in hooks or context. Avoid heavy work in render; offload to hooks or services.",
    "Follow a single source of truth for theme: colors, spacing, radii, typography in Tailwind config or CSS variables.",
    "Model → Service → Hook → Component flow. Components never call services directly; they use hooks.",
    "When adding a new feature, check components/, hooks/, lib/, and services/ for existing helpers before writing new code.",
    "All new public APIs must include brief JSDoc comments explaining intent, parameters, and side effects.",
    "Prefer pure functions and small units. Extract repeated component snippets into reusable components. Extract repeated queries/data transforms into hooks or services.",
    "All database and network access goes through services/ or Supabase client. Use React Query for data fetching and caching."
  ],

  "file_rules": [
    {
      "pattern": "src/pages/**/*.tsx",
      "instructions": [
        "Use functional components with small, readable bodies. Break large components into smaller sub-components.",
        "NEVER duplicate component patterns; extract repeated patterns into reusable components in src/components/.",
        "No business logic in components. Forward user intents to hooks or services.",
        "Use React hooks (useState, useEffect, useQuery) correctly. Keep components focused on presentation."
      ]
    },
    {
      "pattern": "src/components/**/*.tsx",
      "instructions": [
        "Components must be reusable and generic. Accept props for configuration.",
        "Any UI pattern used 2+ times must be a component (e.g., PrimaryButton, DuoCard, ChatBubble).",
        "Components must be generic-friendly and configurable via props. No business logic here.",
        "Use TypeScript interfaces for props. Make props optional where appropriate."
      ]
    },
    {
      "pattern": "src/hooks/**/*.ts",
      "instructions": [
        "Single-responsibility. Expose clear hooks (e.g., useAuth, useMatchmaking, useChat).",
        "No duplication of Supabase calls; reuse service functions or create shared hooks.",
        "Use React Query for data fetching, caching, and synchronization.",
        "Handle loading and error states properly. Return clear, typed data."
      ]
    },
    {
      "pattern": "src/services/**/*.ts",
      "instructions": [
        "Define service functions for Supabase operations. Group related operations together.",
        "Keep all queries/util functions DRY in this layer. If a new call resembles an existing one, generalize the existing function.",
        "Return typed data or throw errors; never silently fail.",
        "Centralize retry/backoff and error handling in a small shared helper; do not repeat per-call logic."
      ]
    },
    {
      "pattern": "src/lib/**/*.ts",
      "instructions": [
        "House small cross-cutting helpers (formatting, date utils, validation, type guards).",
        "If a helper exists, extend it—do not create siblings that do the same thing.",
        "Use TypeScript types and interfaces. Export types that are used in multiple places."
      ]
    },
    {
      "pattern": "src/integrations/**/*.ts",
      "instructions": [
        "Supabase client and type definitions. Keep this minimal and focused.",
        "Export Supabase client instance. Export generated types from Supabase."
      ]
    }
  ],

  "rewrite_rules": [
    {
      "trigger": "duplicate logic detected",
      "action": "Extract to lib/, hooks/, or services/ with a single generalized function; update all call sites accordingly."
    },
    {
      "trigger": "repeated component patterns",
      "action": "Create a reusable component in src/components/ that encapsulates the pattern; replace duplicates."
    },
    {
      "trigger": "similar Supabase queries",
      "action": "Create a single parameterized function in services/; deprecate duplicates."
    }
  ],

  "style_guide": {
    "typescript": {
      "naming": "camelCase for vars/functions, PascalCase for types/components. Clear, intention-revealing names.",
      "docs": "Use JSDoc comments for public functions. Add short rationale for non-trivial private helpers.",
      "errors": "Use typed errors or Error objects. Provide human-friendly messages at the component level.",
      "async": "Prefer async/await over promises. Use React Query for data fetching. Handle errors properly.",
      "testing": "Write tests for services and hooks. Keep logic testable without UI."
    },
    "react": {
      "components": "Use functional components with TypeScript. Use hooks for state and side effects.",
      "props": "Define props interfaces. Use default props where appropriate. Keep props minimal.",
      "state": "Use useState for local state, useContext for shared state, React Query for server state.",
      "effects": "Use useEffect for side effects. Clean up subscriptions and timers. Include proper dependencies."
    }
  },

  "generation_recipes": [
    {
      "name": "CreateComponent+Hook",
      "prompt": "Generate a React component and a matching custom hook. Component must be a functional component, stateless except for props and hook usage. Hook must handle state and side effects, using React Query for data fetching. No direct Supabase calls inside component; all through hooks."
    },
    {
      "name": "AddServiceFunction",
      "prompt": "Create a service function for Supabase operations. Group related operations together. Move all similar/duplicate query code into one parameterized function. Provide TypeScript types for parameters and return values."
    },
    {
      "name": "RefactorToDRY",
      "prompt": "Identify repeated functions or component patterns. Extract them into lib/, hooks/, services/, or components/ respectively. Replace all duplicates across the codebase. Maintain identical behavior and add brief docs."
    }
  ],

  "acceptance_criteria": [
    "No duplicate functions across files. Cursor must refactor to a single shared implementation if any are introduced.",
    "All theme values used via Tailwind config or CSS variables, not hard-coded.",
    "Components contain no business logic or direct Supabase calls.",
    "All services are typed with TypeScript. Use React Query for data fetching.",
    "Public APIs and non-trivial helpers have JSDoc comments.",
    "Builds cleanly with TypeScript. No any types without justification. Proper error handling."
  ]
}
